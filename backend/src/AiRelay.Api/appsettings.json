{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=AiRelay;Username=postgres;Password=dummy_password_for_ef_migrations"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowAnyLocalhost": false,
    "AllowedOrigins": []
  },
  "DefaultAdmin": {
    "Username": "admin",
    "Password": "Admin@123456",
    "Email": "admin@ai-relay.com",
    "Nickname": "系统管理员"
  },
  "Jwt": {
    "SecretKey": "AiRelay-SuperSecretKey-ForDevelopment-MinimumLength32Characters!",
    "Issuer": "AiRelay",
    "Audience": "AiRelay"
  },
  "ExternalAuth": {
    "GitHub": {
      "ClientId": "your-github-client-id",
      "ClientSecret": "your-github-client-secret",
      "RedirectUri": "http://localhost:5000/api/external-auth/github/callback"
    },
    "Google": {
      "ClientId": "your-google-client-id",
      "ClientSecret": "your-google-client-secret",
      "RedirectUri": "http://localhost:5000/api/external-auth/google/callback"
    }
  },
  "ModelPricing": {
    "RemoteUrl": "https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json"
  },
  "Leistd": {
    "GlobalException": {
      "Enable": true,
      "ExcludePathPatterns": []
    }
  }
}